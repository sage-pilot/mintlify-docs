{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Sagepilot Docs",
  "description": "Product documentation for Sagepilot workspaces, support operations, AI agents, engagement, integrations, analytics, and settings.",
  "colors": {
    "primary": "#166E3F",
    "light": "#22E185",
    "dark": "#22E185"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "javascript", "python"],
      "defaults": "required",
      "prefill": false,
      "autogenerate": true
    },
    "mdx": {
      "server": ["https://app.sagepilot.ai", "https://eu.sagepilot.ai"],
      "auth": {
        "method": "bearer"
      }
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@sagepilot.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to Platform",
      "href": "https://app.sagepilot.ai"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Open Platform",
          "icon": "laptop",
          "href": "https://app.sagepilot.ai"
        }
      ]
    },
    "tabs": [
      {
        "tab": "SDKs",
        "icon": "smartphone",
        "groups": [
          {
            "group": "React Native SDK",
            "root": "sdks/react-native/overview",
            "expanded": true,
            "pages": [
              "sdks/react-native/installation",
              "sdks/react-native/configuration",
              "sdks/react-native/secure-session-storage",
              "sdks/react-native/identity",
              "sdks/react-native/opening-chat",
              "sdks/react-native/api-reference"
            ]
          }
        ]
      },
      {
        "tab": "MCP",
        "icon": "server-cog",
        "groups": [
          {
            "group": "Sagepilot MCP",
            "root": "mcp/overview",
            "expanded": true,
            "pages": [
              "mcp/authentication",
              "mcp/clients",
              "mcp/openai-responses-api",
              "mcp/tools",
              "mcp/ticket-list-filters"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Overview",
            "icon": "square-terminal",
            "root": "api-reference/overview",
            "expanded": true,
            "pages": [
              "api-reference/authentication/api-client-v2",
              "api-reference/authentication/legacy-workspace-api-key"
            ]
          },
          {
            "group": "Analytics",
            "icon": "chart-no-axes-combined",
            "expanded": true,
            "pages": [
              "api-reference/analytics/catalog",
              "api-reference/analytics/query"
            ]
          },
          {
            "group": "Tickets",
            "icon": "ticket",
            "root": "api-reference/tickets",
            "expanded": true,
            "pages": [
              "api-reference/tickets/list",
              "api-reference/tickets/export",
              "api-reference/tickets/mark-read",
              "api-reference/tickets/assign",
              "api-reference/tickets/status",
              "api-reference/tickets/messages-list"
            ]
          },
          {
            "group": "Calls",
            "icon": "phone-call",
            "root": "api-reference/calls",
            "expanded": true,
            "pages": [
              "api-reference/calls/export-voice-calls"
            ]
          },
          {
            "group": "Customers",
            "icon": "users",
            "root": "api-reference/customers",
            "expanded": true,
            "pages": [
              "api-reference/customers/recent-chats",
              "api-reference/customers/notes",
              "api-reference/customers/recent-calls",
              "api-reference/customers/backoffice-tickets",
              "api-reference/customers/tickets-stats",
              "api-reference/customers/social-activity",
              "api-reference/customers/linked-contacts",
              "api-reference/customers/list",
              "api-reference/customers/get",
              "api-reference/customers/get-by-id"
            ]
          },
          {
            "group": "Messages",
            "expanded": true,
            "pages": [
              "api-reference/messages/send-whatsapp-template"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://sagepilot.ai/",
      "linkedin": "https://www.linkedin.com/company/sagepilot-ai/"
    }
  }
}
