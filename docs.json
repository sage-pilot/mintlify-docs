{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Sagepilot Docs",
  "description": "Product documentation for Sagepilot workspaces, support operations, AI agents, engagement, integrations, analytics, and settings.",
  "colors": {
    "primary": "#166E3F",
    "light": "#22E185",
    "dark": "#22E185"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@sagepilot.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to Platform",
      "href": "https://app.sagepilot.ai"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Open Platform",
          "icon": "laptop",
          "href": "https://app.sagepilot.ai"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "root": "getting-started/overview",
            "expanded": true,
            "pages": [
              "getting-started/workspace-setup",
              "getting-started/connect-your-first-channel",
              "getting-started/invite-your-team"
            ]
          },
          {
            "group": "Support inbox",
            "root": "support-inbox/overview",
            "expanded": true,
            "pages": [
              "support-inbox/tickets-and-views",
              "support-inbox/customers",
              "support-inbox/calls"
            ]
          },
          {
            "group": "AI agents",
            "root": "ai-agents/overview",
            "expanded": true,
            "pages": [
              "ai-agents/support-agents",
              "ai-agents/voice-agents",
              "ai-agents/knowledge-base",
              "ai-agents/manager-mode"
            ]
          },
          {
            "group": "Engage",
            "root": "engage/overview",
            "expanded": true,
            "pages": [
              "engage/lists-and-segments",
              "engage/templates",
              "engage/journeys",
              "engage/marketing-ai",
              "engage/campaign-history"
            ]
          },
          {
            "group": "Analytics",
            "root": "analytics/overview",
            "expanded": true,
            "pages": [
              "analytics/support-analytics",
              "analytics/ai-performance",
              "analytics/outbound-analytics"
            ]
          },
          {
            "group": "Workspace settings",
            "root": "settings/overview",
            "expanded": true,
            "pages": [
              "settings/team-and-permissions",
              "settings/billing",
              "settings/branding"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "icon": "plug",
        "groups": [
          {
            "group": "Integrations",
            "root": "integrations/overview",
            "expanded": true,
            "pages": [
              "integrations/channels",
              "integrations/ecommerce",
              "integrations/helpdesk-and-crm",
              "integrations/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "icon": "smartphone",
        "groups": [
          {
            "group": "React Native SDK",
            "root": "sdks/react-native/overview",
            "expanded": true,
            "pages": [
              "sdks/react-native/installation",
              "sdks/react-native/configuration",
              "sdks/react-native/secure-session-storage",
              "sdks/react-native/identity",
              "sdks/react-native/opening-chat",
              "sdks/react-native/api-reference"
            ]
          }
        ]
      },
      {
        "tab": "MCP",
        "icon": "network",
        "groups": [
          {
            "group": "Sagepilot MCP",
            "root": "mcp/overview",
            "expanded": true,
            "pages": [
              "mcp/authentication",
              "mcp/clients",
              "mcp/openai-responses-api",
              "mcp/tools",
              "mcp/ticket-list-filters"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Overview",
            "root": "api-reference/overview",
            "expanded": true,
            "pages": [
              "api-reference/authentication"
            ]
          },
          {
            "group": "Resources",
            "expanded": true,
            "pages": [
              "api-reference/tickets",
              "api-reference/customers",
              "api-reference/channels",
              "api-reference/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "history",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/sagepilot-ai/"
    }
  }
}
